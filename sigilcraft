        function hideIntegrationModal() {
            const modal = document.getElementById('modal-backdrop');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }
        
        function logPeak() {
            const notif = document.createElement('div');
            notif.style.cssText = 'position:fixed; bottom:30px; right:30px; background:#111; border:2px solid #00f7ff; padding:16px 24px; border-radius:9999px; color:#00f7ff; font-family:monospace; box-shadow:0 0 20px #00f7ff;';
            notif.innerHTML = '✅ PEAK EXPERIENCE LOGGED<br><span class="text-xs">+1 to your streak • Integration cycle advanced</span>';
            document.body.appendChild(notif);
            setTimeout(() => notif.remove(), 3200);
        }
        
