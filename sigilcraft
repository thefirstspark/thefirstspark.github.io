    <script>
        // Tailwind
        function initializeTailwind() {
            // CDN already loaded
        }

        // Background Canvas - DOPE AF cosmic animation
        let bgCanvas, bgCtx;
        let particles = [];
        let floatingSigils = [];
        
        class Particle {
            constructor() {
                this.x = Math.random() * window.innerWidth;
                this.y = Math.random() * window.innerHeight;
                this.size = Math.random() * 3 + 0.5;
                this.speedX = Math.random() * 0.5 - 0.25;
                this.speedY = Math.random() * 0.5 - 0.25;
                this.hue = Math.random() > 0.7 ? 180 : 45; // cyan or gold
            }
            update() {
                this.x += this.speedX;
                this.y += this.speedY;
                if (this.x < 0 || this.x > window.innerWidth) this.speedX *= -1;
                if (this.y < 0 || this.y > window.innerHeight) this.speedY *= -1;
                this.size = Math.max(0.3, this.size + Math.random() * 0.1 - 0.05);
            }
            draw() {
                bgCtx.save();
                bgCtx.globalAlpha = Math.random() * 0.9 + 0.3;
                bgCtx.fillStyle = this.hue === 180 ? '#00f7ff' : '#ffcc00';
                bgCtx.shadowBlur = 12;
                bgCtx.shadowColor = this.hue === 180 ? '#00f7ff' : '#ffcc00';
                bgCtx.fillRect(this.x, this.y, this.size, this.size);
                bgCtx.restore();
            }
        }
        
        class FloatingSigil {
            constructor() {
                this.x = Math.random() * window.innerWidth;
                this.y = Math.random() * window.innerHeight;
                this.size = Math.random() * 40 + 20;
                this.rotation = Math.random() * 360;
                this.rotSpeed = (Math.random() - 0.5) * 0.3;
                this.opacity = Math.random() * 0.15 + 0.05;
                this.speedY = Math.random() * 0.3 + 0.1;
            }
            update() {
                this.y += this.speedY;
                this.rotation += this.rotSpeed;
                if (this.y > window.innerHeight + 100) this.y = -100;
            }
            draw() {
                bgCtx.save();
                bgCtx.translate(this.x, this.y);
                bgCtx.rotate(this.rotation * Math.PI / 180);
                bgCtx.globalAlpha = this.opacity;
                bgCtx.strokeStyle = '#00f7ff';
                bgCtx.lineWidth = 3;
                // Mini sigil
                bgCtx.beginPath();
                bgCtx.moveTo(0, -this.size/2);
                bgCtx.lineTo(this.size/2 * 0.8, this.size/2 * 0.6);
                bgCtx.lineTo(-this.size/2 * 0.8, this.size/2 * 0.6);
                bgCtx.closePath();
                bgCtx.stroke();
                bgCtx.beginPath();
                bgCtx.arc(0, 0, this.size/4, 0, Math.PI * 2);
                bgCtx.stroke();
                bgCtx.restore();
            }
        }
        
        function initBackground() {
            bgCanvas = document.getElementById('background-canvas');
            bgCtx = bgCanvas.getContext('2d');
            
            function resize() {
                bgCanvas.width = window.innerWidth;
                bgCanvas.height = window.innerHeight;
            }
            window.addEventListener('resize', resize);
            resize();
            
            // Spawn particles
            for (let i = 0; i < 420; i++) {
                particles.push(new Particle());
            }
            
            // Spawn floating sigils
            for (let i = 0; i < 8; i++) {
                floatingSigils.push(new FloatingSigil());
            }
            
            function animateBackground() {
                bgCtx.fillStyle = 'rgba(0, 0, 17, 0.12)';
                bgCtx.fillRect(0, 0, bgCanvas.width, bgCanvas.height);
                
                // Draw particles
                particles.forEach(p => {
                    p.update();
                    p.draw();
                });
                
                // Draw floating sigils
                floatingSigils.forEach(s => {
                    s.update();
                    s.draw();
                });
                
                // Occasional bright pulse (nebula flare)
                if (Math.random() < 0.015) {
                    bgCtx.save();
                    bgCtx.globalAlpha = 0.25;
                    const grad = bgCtx.createRadialGradient(
                        bgCanvas.width * Math.random(), 
                        bgCanvas.height * Math.random(), 
                        10, 
                        bgCanvas.width * Math.random(), 
                        bgCanvas.height * Math.random(), 
                        300
                    );
                    grad.addColorStop(0, '#00f7ff');
                    grad.addColorStop(1, 'transparent');
                    bgCtx.fillStyle = grad;
                    bgCtx.fillRect(0, 0, bgCanvas.width, bgCanvas.height);
                    bgCtx.restore();
                }
                
                requestAnimationFrame(animateBackground);
            }
            animateBackground();
            
            console.log('%c🌌 DOPE AF BACKGROUND INITIALIZED — The Sparkverse is alive', 'color:#00f7ff; font-size:14px');
        }
        
        // Tab switching
        let currentTab = 0;
        function switchTab(tabIndex) {
            currentTab = tabIndex;
            document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.add('hidden'));
            document.getElementById('panel-' + tabIndex).classList.remove('hidden');
            
            document.querySelectorAll('button[id^="tab-"]').forEach(btn => btn.classList.remove('tab-active'));
            document.getElementById('tab-' + tabIndex).classList.add('tab-active');
        }
        
        // STATEMENT-BASED SIGIL GENERATOR
        function generateStatementSigil() {
            const input = document.getElementById('intention-input').value.trim().toUpperCase();
            if (!input) return alert("Enter an intention first.");
            
            let cleaned = input.replace(/[^A-Z]/g, '').replace(/[AEIOU]/g, '');
            cleaned = [...new Set(cleaned)].join('');
            
            const svg = document.getElementById('statement-sigil');
            svg.innerHTML = `
                <path d="M100 30 L170 150 L30 150 Z" stroke="#00f7ff" stroke-width="12" stroke-linejoin="round" opacity="0.9"/>
                <circle cx="100" cy="100" r="45" stroke="#00f7ff" stroke-width="8" opacity="0.8"/>
                <circle cx="100" cy="100" r="28" stroke="#00f7ff" stroke-width="8" opacity="0.6"/>
                <circle cx="100" cy="100" r="10" fill="#ffcc00"/>
                ${Array.from(cleaned).map((char, i) => {
                    const angle = (i * 360 / cleaned.length) * Math.PI / 180;
                    const x1 = 100 + Math.cos(angle) * 35;
                    const y1 = 100 + Math.sin(angle) * 35;
                    const x2 = 100 + Math.cos(angle * 1.3) * 65;
                    const y2 = 100 + Math.sin(angle * 1.3) * 65;
                    return `<line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" stroke="#ffcc00" stroke-width="4" opacity="0.7"/>`;
                }).join('')}
                <path d="M65 165 Q80 185 100 165 Q120 145 140 165" stroke="#00f7ff" stroke-width="12" fill="none"/>
                <text x="100" y="195" text-anchor="middle" fill="#ffffff" opacity="0.15" font-size="11">${cleaned}</text>
            `;
            svg.classList.remove('hidden');
            document.getElementById('statement-placeholder').classList.add('hidden');
        }
        
        // CHANNELLED CANVAS
        let canvas, ctx, isDrawing = false;
        function initCanvas() {
            canvas = document.getElementById('channel-canvas');
            ctx = canvas.getContext('2d');
            ctx.strokeStyle = '#00f7ff';
            ctx.lineWidth = 7;
            ctx.lineJoin = 'round';
            ctx.shadowBlur = 30;
            ctx.shadowColor = '#00f7ff';
            
            canvas.addEventListener('mousedown', startDrawing);
            canvas.addEventListener('mousemove', draw);
            canvas.addEventListener('mouseup', stopDrawing);
            canvas.addEventListener('mouseout', stopDrawing);
            
            canvas.addEventListener('touchstart', e => { e.preventDefault(); startDrawing(e.touches[0]); });
            canvas.addEventListener('touchmove', e => { e.preventDefault(); draw(e.touches[0]); });
            canvas.addEventListener('touchend', stopDrawing);
        }
        
        function startDrawing(e) {
            isDrawing = true;
            ctx.beginPath();
            const rect = canvas.getBoundingClientRect();
            ctx.moveTo(e.clientX - rect.left, e.clientY - rect.top);
        }
        
        function draw(e) {
            if (!isDrawing) return;
            const rect = canvas.getBoundingClientRect();
            ctx.lineTo(e.clientX - rect.left, e.clientY - rect.top);
            ctx.stroke();
        }
        
        function stopDrawing() {
            isDrawing = false;
        }
        
        function clearCanvas() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
        }
        
        function saveChannelledSigil() {
            const link = document.createElement('a');
            link.download = 'channelled-sigil-' + Date.now() + '.png';
            link.href = canvas.toDataURL('image/png');
            link.click();
            alert("✺ Sigil saved to your personal grimoire. Logged in the Sparkverse.");
        }
        
        // DESTRUCTION RITUAL
        function createDestructionSigil() {
            const svg = document.getElementById('destruction-sigil');
            svg.innerHTML = `
                <path d="M100 30 L170 150 L30 150 Z" stroke="#ff5500" stroke-width="18" stroke-linejoin="round"/>
                <circle cx="100" cy="100" r="42" stroke="#ffcc00" stroke-width="10"/>
                <circle cx="100" cy="100" r="22" fill="#ff5500"/>
                <path d="M65 165 Q80 185 100 165 Q120 145 140 165" stroke="#ff5500" stroke-width="14" fill="none"/>
            `;
        }
        
        function performDestructionRitual() {
            const container = document.getElementById('destruction-sigil-container');
            container.classList.add('burning');
            setTimeout(() => {
                alert("🔥 The sigil has been destroyed.\n\nErasure complete.\nThe black orchid opens.\nYou are lighter. You are sovereign.");
                container.classList.remove('burning');
                document.getElementById('destruction-sigil').innerHTML = '';
            }, 2800);
        }
        
        // CHARGE SIGIL
        function chargeSigil(type) {
            const messages = {
                statement: "⚡ GNOSIS ACHIEVED. The command line has been executed in your subconscious.",
                channelled: "🌌 THE GLITCH LIVED. Your hand became the programmer.",
                destruction: "🜁 DUST TO SILENCE. Reclamation is complete."
            };
            
            const el = document.createElement('div');
            el.style.cssText = 'position:fixed; top:50%; left:50%; transform:translate(-50%,-50%); background:rgba(0,247,255,0.95); color:#000; padding:24px 40px; border-radius:9999px; font-weight:700; font-size:1.3rem; box-shadow:0 0 60px #00f7ff; z-index:99999; white-space:nowrap;';
            el.textContent = messages[type] || 'SIGIL CHARGED';
            document.body.appendChild(el);
            
            setTimeout(() => {
